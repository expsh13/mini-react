{
  "name": "mini-react",
  "version": "0.1.0",
  "description": "A minimal React 18 implementation for learning purposes",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ch02": "vitest run tests/createElement",
    "test:ch03": "vitest run tests/render",
    "test:ch04": "vitest run tests/fiber",
    "test:ch05": "vitest run tests/workLoop",
    "test:ch06": "vitest run tests/commit",
    "test:ch07": "vitest run tests/useState",
    "test:ch08": "vitest run tests/useEffect",
    "test:ch09": "vitest run tests/integration",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "jsdom": "^28.1.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
